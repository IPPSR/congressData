# PREP
# make subsets of data for the different sections
com <- codebook[grepl("com_", codebook[["variable"]]), ]
nbl <- codebook[grepl("nbills_", codebook[["variable"]]), ]
cen <- codebook[grepl("Data API", codebook[["sources"]]), ] %>%
filter(category == "demographics")
all_else <- codebook[!grepl("com_|nbills_", codebook[["variable"]]), ]
all_else <- all_else[!grepl("Data API", all_else[["sources"]]), ]
# verify
# subset_rows <- nrow(com) + nrow(nbl) + nrow(cen) + nrow(all_else)
# subset_rows == nrow(codebook)
# setdiff(codebook$variable, c(com$variable,nbl$variable,cen$variable,all_else$variable))
makebook <- function(dat){
dat %>%
mutate(variable = gsub('(.{1,15})', '\\1\n', variable)) %>%
select(variable,years,long_desc,sources) %>%
kbl(format ="latex"
,row.names = F
,col.names = c("Variable","Years","Description","Source(s) and Notes")
,align = c("l","c","l","l")
,booktabs = T
,longtable = T
,linesep = "\\addlinespace"
) %>%
kable_styling(font_size = 7
# ,full_width = TRUE
) %>%
# row_spec(0, bold=T) %>%
column_spec(1, width = "8em") %>%
column_spec(2, width = "6em") %>%
# column_spec(3, width = "8em") %>%
column_spec(3, width = "15em") %>%
column_spec(4, width = "28em")
}
makebook(com)
cen %>%
mutate(variable = gsub('(.{1,15})', '\\1\n', variable)) %>%
select(variable,years,long_desc,sources) %>%
kbl(format ="latex"
,row.names = F
,col.names = c("Variable","Years","Description","Source(s) and Notes")
,align = c("l","c","l","l")
,booktabs = T
,longtable = T
,linesep = "\\addlinespace"
) %>%
kable_styling(font_size = 7
# ,full_width = TRUE
) %>%
# row_spec(0, bold=T) %>%
column_spec(1, width = "8em") %>%
column_spec(2, width = "6em") %>%
# column_spec(3, width = "8em") %>%
column_spec(3, width = "15em") %>%
column_spec(4, width = "28em")
makebook(nbl)
all_else %>%
mutate(variable = gsub('(.{1,15})', '\\1\n', variable)) %>%
select(variable,years,long_desc,sources) %>%
kbl(format ="latex"
,row.names = F
,col.names = c("Variable","Years","Description","Source(s) and Notes")
,align = c("l","c","l","l")
,booktabs = T
,longtable = T
,linesep = "\\addlinespace"
) %>%
kable_styling(font_size = 7
# ,full_width = TRUE
) %>%
# row_spec(0, bold=T) %>%
column_spec(1, width = "8em") %>%
column_spec(2, width = "6em") %>%
# column_spec(3, width = "8em") %>%
column_spec(3, width = "15em") %>%
column_spec(4, width = "28em")
View(congress)
